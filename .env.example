# xAI Grok API
XAI_API_KEY=your_xai_api_key
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3

# 微信后端：db_keyboard=数据库监听+键盘发消息（推荐）；pyweixin=UI自动化；wcferry=旧版3.9
WECHAT_BACKEND=db_keyboard

# db_keyboard：64 位十六进制数据库密钥（wx_key 工具提取，路径勿含中文）
# 下载：https://github.com/ycccccccy/wx_key/releases
WECHAT_DB_KEY=
DB_POLL_INTERVAL_SEC=1.0

# WeChatFerry（个人微信，需 Windows + PC 微信 3.9.x）
# 本机运行留空；连接远程 Windows 填 IP，如 192.168.1.100
WCF_HOST=
WCF_PORT=10086

# wcferry 白名单：留空=所有好友；填写 wxid 逗号分隔
ALLOWED_WXIDS=
# pyweixin 白名单：留空=所有好友；填写好友备注/昵称逗号分隔
ALLOWED_FRIENDS=
# 是否在群聊被 @ 时回复
REPLY_IN_GROUP=false

# WhatsApp 机器人（run_whatsapp.py / 启动WhatsApp机器人.bat）
WHATSAPP_SESSION_NAME=grok-whatsapp
# 留空=所有联系人；填写国际手机号逗号分隔，如 8613800138000
ALLOWED_WHATSAPP_NUMBERS=
WHATSAPP_REPLY_IN_GROUP=false
WHATSAPP_REPLY_TO_SELF=true

MAX_HISTORY_TURNS=10
SYSTEM_PROMPT=你是一个友好、简洁的中文 AI 助手，由 Grok 驱动。回答要准确、有条理。